# Gemini API key (REQUIRED) — get one at https://aistudio.google.com/apikey
# Set just this one. (The code also accepts GEMINI_API_KEY or
# GOOGLE_GENERATIVE_AI_API_KEY as fallback aliases for compatibility with
# different Google SDK examples — pick whichever name you prefer.)
GOOGLE_API_KEY=

# Gemini model override (default: gemini-1.5-pro)
VERTEX_AI_MODEL=gemini-flash-latest

# Google Cloud Platform (used by production stubs)
GCP_PROJECT_ID=
GCP_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

# Document AI (production path — stub today, see lib/gcp/documentai.ts)
DOCUMENT_AI_PROCESSOR_ID=

# BigQuery (production path — stub today, see lib/gcp/bigquery.ts)
BIGQUERY_DATASET=

# Africa's Talking SMS — leave AT_API_KEY blank to run in demo mode
AT_USERNAME=sandbox
AT_API_KEY=
AT_SHORTCODE=

# Cloud Scheduler secret for /api/cron
CRON_SECRET=
